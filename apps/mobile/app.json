{
  "expo": {
    "name": "solito-blank",
    "slug": "solito-blank",
    "version": "1.0.0",
    "scheme": "solito-blank",
    "main": "index.js",
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "Cho phép Tokki truy cập micro để luyện phát âm."
        }
      ]
    ],
    "ios": {

      "bundleIdentifier": "com.solito.blank"
    },
    "newArchEnabled": true,
    "experiments": {
      "reactCanary": true
    },
    "android": {
      "package": "com.solito.blank",
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS"
      ],
      "navigationBar": {
        "backgroundColor": "#000000",
        "barStyle": "light-content"
      }
    }

  }
}

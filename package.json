{
  "name": "solito-blank",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web": "npm run dev --workspace=apps/web",
    "native": "npm run start --workspace=apps/mobile",
    "android": "npm run android --workspace=apps/mobile",
    "ios": "npm run ios --workspace=apps/mobile"
  },
  "packageManager": "npm@10.2.0",
  "eslintConfig": {
    "extends": "next",
    "settings": {
      "next": {
        "rootDir": "apps/web/"
      }
    },
    "root": true
  },
  "prettier": {
    "semi": false,
    "useTabs": false,
    "tabWidth": 2,
    "singleQuote": true
  },
  "dependencies": {
    "@microsoft/signalr": "^10.0.0",
    "@tanstack/react-query": "^5.90.12",
    "antd": "^6.0.1",
    "axios": "^1.13.2",
    "canvas-confetti": "^1.9.4",
    "howler": "^2.2.4",
    "i": "^0.3.7",
    "jwt-decode": "^4.0.0",
    "react-quill": "^2.0.0",
    "react-quill-new": "^3.7.0",
    "recharts": "^3.5.1",
    "sharp": "^0.34.5",
    "xlsx": "^0.18.5"
  }
}

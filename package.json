{
  "name": "solito-blank",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web": "npm run dev --workspace=apps/web",
    "native": "npm run start --workspace=apps/mobile",
    "android": "npm run android --workspace=apps/mobile",
    "ios": "npm run ios --workspace=apps/mobile"
  },
  "packageManager": "npm@10.2.0",
  "eslintConfig": {
    "extends": "next",
    "settings": {
      "next": {
        "rootDir": "apps/web/"
      }
    },
    "root": true
  },
  "prettier": {
    "semi": false,
    "useTabs": false,
    "tabWidth": 2,
    "singleQuote": true
  },
  "dependencies": {
    "@microsoft/signalr": "^10.0.0",
    "@react-native/assets-registry": "^0.85.2",
    "@react-native/virtualized-lists": "^0.85.2",
    "@tanstack/react-query": "^5.90.12",
    "antd": "^6.0.1",
    "antd-img-crop": "^4.30.0",
    "axios": "^1.13.2",
    "canvas-confetti": "^1.9.4",
    "emoji-picker-react": "^4.19.1",
    "expo": "~54.0.31",
    "howler": "^2.2.4",
    "i": "^0.3.7",
    "jwt-decode": "^4.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-joyride": "^2.9.3",
    "react-native-svg": "^15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-webview": "^13.16.1",
    "react-quill": "^2.0.0",
    "react-quill-new": "^3.7.0",
    "recharts": "^3.5.1",
    "sharp": "^0.34.5",
    "xlsx": "^0.18.5"
  }
}